---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  image?: string;
}

const {
  title,
  description,
  lang,
  image = '/social-card.svg'
} = Astro.props;

const siteName = 'Roberto Millan';
const origin = Astro.site ?? new URL('https://robertomillan.dev');
const canonical = new URL(Astro.url.pathname, origin).toString();
const ogImage = new URL(image, origin).toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteName,
  jobTitle: 'Fullstack Developer',
  description,
  url: canonical,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Valencia',
    addressCountry: 'ES'
  },
  knowsAbout: [
    'Python',
    'Django',
    'React',
    'TypeScript',
    'Odoo',
    'PostgreSQL',
    'Docker',
    'Astro'
  ]
};
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b1220" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = storedTheme ?? systemTheme;
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Navbar lang={lang} currentPath={Astro.url.pathname} />
    <main id="content">
      <slot />
    </main>
    <script is:inline>
      const root = document.documentElement;
      const toggle = document.querySelector('[data-theme-toggle]');
      const label = document.querySelector('[data-theme-label]');

      if (toggle && label) {
        const syncTheme = () => {
          const isDark = root.dataset.theme === 'dark';
          const darkLabel = toggle.dataset.labelDark || 'Dark';
          const lightLabel = toggle.dataset.labelLight || 'Light';
          const darkAria = toggle.dataset.ariaDark || 'Switch to dark theme';
          const lightAria = toggle.dataset.ariaLight || 'Switch to light theme';
          toggle.setAttribute('aria-pressed', String(isDark));
          toggle.setAttribute('aria-label', isDark ? lightAria : darkAria);
          label.textContent = isDark ? lightLabel : darkLabel;
        };

        syncTheme();

        toggle.addEventListener('click', () => {
          root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
          localStorage.setItem('theme', root.dataset.theme);
          syncTheme();
        });
      }
    </script>
  </body>
</html>
