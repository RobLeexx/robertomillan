---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
import { siteMeta, structuredDataKnowAbout } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = siteMeta.defaultTitle,
  description = siteMeta.description,
  image = siteMeta.ogImage,
  noindex = false
} = Astro.props;

const pageTitle = title === siteMeta.defaultTitle ? `${siteMeta.name} | ${title}` : `${title} | ${siteMeta.name}`;
const origin = Astro.site ?? new URL(siteMeta.fallbackSiteUrl);
const canonical = new URL(Astro.url.pathname, origin).toString();
const ogImage = new URL(image, origin).toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteMeta.name,
  jobTitle: 'Fullstack Developer',
  description: siteMeta.longDescription,
  email: siteMeta.email,
  url: canonical,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'ES'
  },
  worksFor: {
    '@type': 'Organization',
    name: 'Independent consultant'
  },
  knowsAbout: structuredDataKnowAbout
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08111b" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const preferredTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      const theme = savedTheme ?? preferredTheme;
      document.documentElement.dataset.theme = theme;
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <Header currentPath={Astro.url.pathname} />
      <main id="content">
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      const root = document.documentElement;
      const themeToggle = document.querySelector('[data-theme-toggle]');
      const navRoot = document.querySelector('[data-nav-root]');
      const navToggle = document.querySelector('[data-nav-toggle]');
      const navDrawer = document.querySelector('[data-nav-drawer]');
      const navOpenIcon = document.querySelector('[data-menu-open-icon]');
      const navCloseIcon = document.querySelector('[data-menu-close-icon]');

      if (themeToggle) {
        const syncThemeButton = () => {
          const activeTheme = root.dataset.theme || 'dark';
          themeToggle.setAttribute('aria-pressed', String(activeTheme === 'light'));
          themeToggle.setAttribute('aria-label', activeTheme === 'light' ? 'Switch to dark mode' : 'Switch to light mode');
        };

        syncThemeButton();

        themeToggle.addEventListener('click', () => {
          const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
          root.dataset.theme = nextTheme;
          localStorage.setItem('theme', nextTheme);
          syncThemeButton();
        });
      }

      if (navRoot && navToggle && navDrawer) {
        const syncNav = (isOpen) => {
          navRoot.dataset.open = String(isOpen);
          navToggle.setAttribute('aria-expanded', String(isOpen));
          navDrawer.classList.toggle('hidden', !isOpen);
          navOpenIcon?.classList.toggle('hidden', isOpen);
          navCloseIcon?.classList.toggle('hidden', !isOpen);
        };

        syncNav(false);

        navToggle.addEventListener('click', () => {
          const nextState = navRoot.dataset.open !== 'true';
          syncNav(nextState);
        });

        navDrawer.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => syncNav(false));
        });
      }

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealItems = document.querySelectorAll('[data-reveal]');

      if (!reducedMotion && revealItems.length) {
        const observer = new IntersectionObserver(
          (entries, target) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                target.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.18, rootMargin: '0px 0px -40px 0px' }
        );

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
