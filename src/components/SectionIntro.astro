---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<div class:list={['space-y-4', centered && 'mx-auto max-w-3xl text-center']}>
  <span class="eyebrow">{eyebrow}</span>
  <h2 class="text-3xl font-extrabold tracking-tight text-[var(--color-text)] sm:text-4xl">{title}</h2>
  <p class="max-w-3xl text-base leading-8 text-[var(--color-muted)] sm:text-lg">{description}</p>
</div>
