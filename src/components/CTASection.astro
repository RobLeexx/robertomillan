---
import { genericLinkIcon } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  title: string;
  body: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const { title, body, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24" data-reveal>
  <div class="panel-strong overflow-hidden rounded-[2rem] p-8 sm:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div class="space-y-5">
        <span class="eyebrow">Let&apos;s build something useful</span>
        <h2 class="max-w-3xl text-3xl font-extrabold text-[var(--color-text)] sm:text-4xl">{title}</h2>
        <p class="max-w-2xl text-base leading-8 text-[var(--color-muted)] sm:text-lg">{body}</p>
      </div>
      <div class="flex flex-col gap-4 sm:flex-row lg:flex-col">
        <a class="button-primary" href={primaryHref}>
          {primaryLabel}
          <Icon icon={genericLinkIcon} class="size-4" />
        </a>
        <a class="button-secondary" href={secondaryHref}>
          {secondaryLabel}
          <Icon icon={genericLinkIcon} class="size-4" />
        </a>
      </div>
    </div>
  </div>
</section>
