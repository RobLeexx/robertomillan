---
import { ArrowUpRight } from 'lucide-static';
import type { Project } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="panel group flex h-full flex-col rounded-[1.75rem] p-6" data-reveal>
  <span class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">{project.label}</span>
  <h3 class="mt-4 text-2xl font-bold text-[var(--color-text)]">{project.title}</h3>
  <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{project.summary}</p>
  <p class="mt-4 rounded-2xl border border-[rgba(255,255,255,0.06)] bg-[rgba(0,0,0,0.08)] px-4 py-3 text-sm leading-7 text-[var(--color-text)]">
    {project.impact}
  </p>
  <div class="mt-5 flex flex-wrap gap-2">
    {
      project.stack.map((item) => (
        <span class="chip text-xs">{item}</span>
      ))
    }
  </div>
  <a class="mt-6 inline-flex items-center gap-2 font-semibold text-[var(--color-brand)]" href={project.href}>
    Learn more
    <Icon icon={ArrowUpRight} class="size-4" />
  </a>
</article>
