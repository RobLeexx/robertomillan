---
interface Props {
  icon: string;
  class?: string;
  title?: string;
}

const { icon, class: className = 'size-5', title } = Astro.props;
const renderedIcon = icon
  .replace(/stroke="[^"]*"/g, 'stroke="currentColor"')
  .replace(/width="24"/g, 'width="1em"')
  .replace(/height="24"/g, 'height="1em"');
---

<span
  class:list={['inline-flex shrink-0 items-center justify-center leading-none', className]}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  set:html={renderedIcon}
/>
