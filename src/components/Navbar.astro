---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeControl from './ThemeControl.astro';
import { getLocalizedPath, type Lang, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const homePath = getLocalizedPath(lang, '/');
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-brand" href={`${homePath}#home`}>Roberto Millan</a>

    <nav class="site-nav" aria-label="Primary">
      <a href={`${homePath}#about`}>{t('nav.about')}</a>
      <a href={`${homePath}#experience`}>{t('nav.experience')}</a>
      <a href={`${homePath}#projects`}>{t('nav.projects')}</a>
      <a href={`${homePath}#contact`}>{t('nav.contact')}</a>
    </nav>

    <div class="site-actions">
      <LanguageSwitcher lang={lang} currentPath={currentPath} label={t('lang.label')} />
      <ThemeControl
        darkLabel={t('theme.dark')}
        lightLabel={t('theme.light')}
        toDarkLabel={t('theme.toDark')}
        toLightLabel={t('theme.toLight')}
      />
    </div>
  </div>
</header>
