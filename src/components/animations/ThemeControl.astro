---
import themeChainScript from '../../scripts/theme-chain.ts?url';

interface Props {
  darkLabel: string;
  lightLabel: string;
  toDarkLabel: string;
  toLightLabel: string;
  pullChainLabel: string;
}

const {
  darkLabel,
  lightLabel,
  toDarkLabel,
  toLightLabel,
  pullChainLabel
} = Astro.props;
---

<div class="theme-control" data-theme-control>
  <button
    class="theme-toggle"
    type="button"
    data-theme-toggle-control
    aria-label={toDarkLabel}
    aria-pressed="false"
    data-label-dark={darkLabel}
    data-label-light={lightLabel}
    data-aria-dark={toDarkLabel}
    data-aria-light={toLightLabel}
  >
    <span class="theme-toggle__icon theme-toggle__icon--light" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18h6" />
        <path d="M10 22h4" />
        <path d="M12 2a7 7 0 0 0-4 12.75c.6.42 1 1.07 1 1.8V17h6v-.45c0-.73.4-1.38 1-1.8A7 7 0 0 0 12 2Z" />
        <path d="M12 6v4" />
        <path d="M10.5 8.5h3" />
      </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18h6" />
        <path d="M10 22h4" />
        <path d="M12 2a7 7 0 0 0-4 12.75c.6.42 1 1.07 1 1.8V17h6v-.45c0-.73.4-1.38 1-1.8A7 7 0 0 0 12 2Z" />
        <path d="m4 4 16 16" />
      </svg>
    </span>
    <span class="sr-only" data-theme-label>{darkLabel}</span>
  </button>

  <button
    class="pull-chain"
    type="button"
    data-theme-chain
    data-theme-toggle-control
    aria-label={toDarkLabel}
    aria-pressed="false"
    data-label-dark={darkLabel}
    data-label-light={lightLabel}
    data-aria-dark={toDarkLabel}
    data-aria-light={toLightLabel}
  >
    <svg
      class="pull-chain__svg"
      viewBox="0 0 36 64"
      width="36"
      height="64"
      aria-hidden="true"
      focusable="false"
      data-chain-svg
    >
      <path class="pull-chain__path" d="M 18 4 Q 18 24 18 46" data-chain-path />
      <circle class="pull-chain__bead" cx="18" cy="10" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="16" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="22" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="28" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="34" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="40" r="2.1" data-chain-bead />
      <circle class="pull-chain__bead" cx="18" cy="46" r="2.6" data-chain-bead />
      <circle class="pull-chain__weight" cx="18" cy="54" r="5.25" data-chain-weight />
    </svg>
    <span class="sr-only">{pullChainLabel}</span>
  </button>
</div>

<script is:inline type="module" src={themeChainScript}></script>
