---
import { getExperience } from '../data/experience';
import { type Lang, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const experienceSections = getExperience(lang);
const initialSection = experienceSections[0];
---

<section id="experience" class="section section--muted">
  <div class="container stack">
    <p class="eyebrow">{t('experience.eyebrow')}</p>
    <h2>{t('experience.title')}</h2>
    <p class="lead lead--narrow">{t('experience.subtitle')}</p>

    <div
      class="experience-toggle"
      data-experience-toggle
      data-initial-section={initialSection.id}
    >
      <div
        class="experience-toggle__tabs"
        role="tablist"
        aria-label={t('experience.navLabel')}
      >
        {
          experienceSections.map((section, index) => (
            <button
              id={`experience-tab-${section.id}`}
              class:list={['experience-toggle__tab', index === 0 && 'experience-toggle__tab--active']}
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`experience-panel-${section.id}`}
              tabindex={index === 0 ? '0' : '-1'}
              data-experience-tab
              data-target={section.id}
            >
              {section.navLabel}
            </button>
          ))
        }
      </div>

      <div class="experience-toggle__panels">
        {
          experienceSections.map((section, index) => (
            <section
              id={`experience-panel-${section.id}`}
              class:list={[
                'experience-toggle__panel',
                section.emphasis === 'primary' && 'experience-toggle__panel--primary',
                section.emphasis === 'compact' && 'experience-toggle__panel--compact',
                index === 0 && 'experience-toggle__panel--active'
              ]}
              role="tabpanel"
              aria-labelledby={`experience-tab-${section.id}`}
              data-experience-panel
              data-panel={section.id}
              hidden={index === 0 ? undefined : true}
            >
              {
                section.entries.map((entry) => (
                  <article class="experience-toggle__entry">
                    <div class="experience-toggle__entry-top">
                      <div class="experience-toggle__entry-heading">
                        <h3>{entry.title}</h3>
                        <p class="experience-toggle__entry-subtitle">{entry.subtitle}</p>
                      </div>

                      <div class="experience-toggle__entry-meta">
                        <span>{entry.location}</span>
                        <span>{entry.period}</span>
                      </div>
                    </div>

                    <p class="experience-toggle__entry-summary">{entry.summary}</p>

                    <ul class="experience-toggle__highlights" aria-label="Highlights">
                      {entry.highlights.map((highlight) => <li>{highlight}</li>)}
                    </ul>

                    <ul class="badge-list badge-list--compact" aria-label="Technologies">
                      {entry.stack.map((technology) => <li>{technology}</li>)}
                    </ul>
                  </article>
                ))
              }
            </section>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const experienceSection = document.currentScript?.previousElementSibling;

    if (!(experienceSection instanceof HTMLElement)) {
      return;
    }

    const experienceToggle = experienceSection.querySelector('[data-experience-toggle]');

    if (!(experienceToggle instanceof HTMLElement)) {
      return;
    }

    const tabs = Array.from(experienceToggle.querySelectorAll('[data-experience-tab]'));
    const panels = Array.from(experienceToggle.querySelectorAll('[data-experience-panel]'));
    const initialSectionId = experienceToggle.dataset.initialSection;

    if (!tabs.length || !panels.length || !initialSectionId) {
      return;
    }

    const activatePanel = (targetId) => {
      tabs.forEach((tab) => {
        if (!(tab instanceof HTMLButtonElement)) {
          return;
        }

        const isActive = tab.dataset.target === targetId;
        tab.classList.toggle('experience-toggle__tab--active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) {
          return;
        }

        const isActive = panel.dataset.panel === targetId;
        panel.hidden = !isActive;
        panel.classList.toggle('experience-toggle__panel--active', isActive);
      });
    };

    tabs.forEach((tab, index) => {
      if (!(tab instanceof HTMLButtonElement)) {
        return;
      }

      tab.addEventListener('click', () => {
        const targetId = tab.dataset.target;

        if (!targetId) {
          return;
        }

        activatePanel(targetId);
      });

      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft' && event.key !== 'Home' && event.key !== 'End') {
          return;
        }

        event.preventDefault();

        let nextIndex = index;

        if (event.key === 'ArrowRight') {
          nextIndex = (index + 1) % tabs.length;
        } else if (event.key === 'ArrowLeft') {
          nextIndex = (index - 1 + tabs.length) % tabs.length;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = tabs.length - 1;
        }

        const nextTab = tabs[nextIndex];

        if (!(nextTab instanceof HTMLButtonElement)) {
          return;
        }

        const nextTargetId = nextTab.dataset.target;

        if (!nextTargetId) {
          return;
        }

        activatePanel(nextTargetId);
        nextTab.focus();
      });
    });

    activatePanel(initialSectionId);
  })();
</script>
