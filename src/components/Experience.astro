---
import { getExperience } from '../data/experience';
import { type Lang, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const experienceItems = getExperience(lang);
---

<section id="experience" class="section section--muted">
  <div class="container stack">
    <p class="eyebrow">{t('experience.eyebrow')}</p>
    <h2>{t('experience.title')}</h2>
    <div class="experience-list">
      {
        experienceItems.map((item) => (
          <article class="card">
            <p class="card__meta">{item.period}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <ul class="list">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
