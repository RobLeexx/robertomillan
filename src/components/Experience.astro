---
import { experienceItems } from '../data/experience';
---

<section id="experience" class="section section--muted">
  <div class="container stack">
    <p class="eyebrow">Experience</p>
    <h2>Developer experience focused on real delivery.</h2>
    <div class="experience-list">
      {
        experienceItems.map((item) => (
          <article class="card">
            <p class="card__meta">{item.period}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <ul class="list">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
