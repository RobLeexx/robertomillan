---
import { languages } from '../../i18n/ui';
import { getLocalizedPath, type Lang } from '../../i18n/utils';
import englishFlag from '../../../static/eng.jpg';
import spanishFlag from '../../../static/sp.jpg';

interface Props {
  lang: Lang;
  currentPath: string;
  label: string;
}

const { lang, currentPath, label } = Astro.props;
const languageFlags: Record<Lang, typeof englishFlag> = {
  en: englishFlag,
  es: spanishFlag
};
---

<nav class="language-switcher" aria-label={label} data-language-switcher>
  {
    Object.entries(languages).map(([code, name]) => (
      <a
        class:list={['language-switcher__link', lang === code && 'language-switcher__link--active']}
        href={getLocalizedPath(code as Lang, currentPath)}
        hreflang={code}
        lang={code}
        aria-current={lang === code ? 'page' : undefined}
        data-language-link
      >
        <img
          class="language-switcher__flag"
          src={languageFlags[code as Lang].src}
          alt=""
          width="20"
          height="20"
          loading="lazy"
          decoding="async"
        />
        <span class="sr-only">{name}</span>
      </a>
    ))
  }
</nav>

<script>
  import '../../scripts/language-switcher.ts';
</script>
