---
import ThemeControl from '../animations/ThemeControl.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import NavLinks from './NavLinks.astro';
import { siteConfig } from '../../config/site';
import { getLocalizedPath, type Lang, useTranslations } from '../../i18n/utils';
import englishCv from '../../../static/cv/RobertoMillanCVenglish.pdf';
import spanishCv from '../../../static/cv/RobertoMillanCVspanish.pdf';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const homePath = getLocalizedPath(lang, '/');
const cvHref = lang === 'es' ? spanishCv : englishCv;
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-brand-group">
      <a class="site-brand" href={`${homePath}#home`}>{siteConfig.name}</a>
      <a class="site-cv-link" href={cvHref} download>{t('nav.downloadCv')}</a>
    </div>

    <div class="site-theme">
      <ThemeControl
        darkLabel={t('theme.dark')}
        lightLabel={t('theme.light')}
        toDarkLabel={t('theme.toDark')}
        toLightLabel={t('theme.toLight')}
        pullChainLabel={t('theme.pullChain')}
      />
    </div>

    <div class="site-actions">
      <nav class="site-nav" aria-label={t('nav.primaryLabel')}>
        <NavLinks basePath={homePath} links="primary" translate={t} />
      </nav>
      <LanguageSwitcher lang={lang} currentPath={currentPath} label={t('lang.label')} />
    </div>
  </div>
</header>
