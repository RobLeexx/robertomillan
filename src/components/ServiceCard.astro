---
import type { Service } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article class="panel h-full rounded-[1.75rem] p-6" data-reveal>
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="inline-flex size-11 items-center justify-center rounded-2xl bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]">
        <Icon icon={service.icon} class="size-5" />
      </span>
      <h3 class="mt-5 text-2xl font-bold text-[var(--color-text)]">{service.title}</h3>
    </div>
  </div>
  <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{service.summary}</p>
  <p class="mt-4 text-sm font-semibold text-[var(--color-text)]">{service.idealFor}</p>
  <ul class="mt-5 space-y-3 text-sm leading-7 text-[var(--color-muted)]">
    {
      service.deliverables.map((item) => (
        <li class="flex gap-3">
          <span class="mt-2 size-1.5 rounded-full bg-[var(--color-brand)]"></span>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>
</article>
