---
import { ArrowRight, BadgeCheck, Mail, MoveRight } from 'lucide-static';
import { heroHighlights, heroStats, siteMeta } from '../data/site';
import Icon from './Icon.astro';
---

<section class="relative overflow-hidden">
  <div class="mx-auto grid w-full max-w-6xl gap-12 px-6 pb-18 pt-16 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:pb-24 lg:pt-22">
    <div class="space-y-8">
      <div class="space-y-5" data-hero-copy>
        <span class="eyebrow">Fullstack Developer for CRM and automation</span>
        <h1 class="max-w-4xl text-5xl font-extrabold tracking-tight text-[var(--color-text)] sm:text-6xl xl:text-7xl">
          <span class="headline-gradient">
            Fullstack Developer building CRM, automation, and business software for service companies
          </span>
        </h1>
        <p class="max-w-2xl text-lg leading-9 text-[var(--color-muted)] sm:text-xl">
          I design and build custom systems with React, TypeScript, Django, Python, Odoo, Docker, and PostgreSQL, with a focus on workflows that teams actually use.
        </p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row" data-hero-actions>
        <a class="button-primary" href="/projects">
          View projects
          <Icon icon={ArrowRight} class="size-4" />
        </a>
        <a class="button-secondary" href={`mailto:${siteMeta.email}?subject=Portfolio%20Inquiry`}>
          Start a conversation
          <Icon icon={Mail} class="size-4" />
        </a>
      </div>

      <div class="flex flex-wrap gap-3" data-hero-badges>
        {
          heroHighlights.map((item) => (
            <span class="chip text-sm">
              <Icon icon={BadgeCheck} class="size-4 text-[var(--color-brand)]" />
              {item}
            </span>
          ))
        }
      </div>

      <div class="grid gap-4 md:grid-cols-3" data-hero-stats>
        {
          heroStats.map((stat) => (
            <div class="panel rounded-3xl p-5">
              <p class="font-mono-display text-sm uppercase tracking-[0.14em] text-[var(--color-brand)]">{stat.value}</p>
              <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="relative lg:pt-10">
      <div class="panel-strong relative overflow-hidden rounded-[2rem] p-6 sm:p-8" data-hero-panel>
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--color-brand)] to-transparent opacity-70"></div>
        <div class="grid gap-4">
          <div class="rounded-3xl border border-[rgba(255,255,255,0.08)] bg-[rgba(77,208,225,0.08)] p-5" data-hero-card>
            <div class="flex items-center justify-between">
              <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">Recent build</p>
              <Icon icon={MoveRight} class="size-4 text-[var(--color-brand)]" />
            </div>
            <h2 class="mt-4 text-2xl font-bold text-[var(--color-text)]">Odoo CRM for a moving company</h2>
            <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
              Lead management, contracts, duplicate detection, reports, media uploads, messaging workflows, and deployment.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="panel rounded-3xl p-5" data-hero-card>
              <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Workflow coverage</p>
              <p class="mt-3 text-lg font-semibold text-[var(--color-text)]">Lead intake to contract generation</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">Built around real operations, not demo flows.</p>
            </div>
            <div class="panel rounded-3xl p-5" data-hero-card>
              <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Delivery style</p>
              <p class="mt-3 text-lg font-semibold text-[var(--color-text)]">Product thinking plus implementation</p>
              <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">From business rules to frontend polish and deployment.</p>
            </div>
          </div>

          <div class="panel rounded-3xl p-5" data-hero-card>
            <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Where I add value</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-[rgba(255,255,255,0.06)] bg-black/10 p-4">
                <p class="text-sm font-semibold text-[var(--color-text)]">CRM logic</p>
                <p class="mt-2 text-sm text-[var(--color-muted)]">Custom stages, rules, validation, and forms.</p>
              </div>
              <div class="rounded-2xl border border-[rgba(255,255,255,0.06)] bg-black/10 p-4">
                <p class="text-sm font-semibold text-[var(--color-text)]">Automation</p>
                <p class="mt-2 text-sm text-[var(--color-muted)]">Communication loops, documents, and admin workflows.</p>
              </div>
              <div class="rounded-2xl border border-[rgba(255,255,255,0.06)] bg-black/10 p-4">
                <p class="text-sm font-semibold text-[var(--color-text)]">Deployment</p>
                <p class="mt-2 text-sm text-[var(--color-muted)]">Docker, VPS, and production-ready releases.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
