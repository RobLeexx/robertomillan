---
import type { CollectionEntry } from 'astro:content';
import { ArrowRight } from 'lucide-static';
import Icon from './Icon.astro';

interface Props {
  entry: CollectionEntry<'case-studies'>;
}

const { entry } = Astro.props;
---

<article class="panel-strong overflow-hidden rounded-[2rem] p-8 sm:p-10" data-reveal>
  <div class="grid gap-8 lg:grid-cols-[1fr_0.75fr] lg:items-start">
    <div>
      <span class="eyebrow">Featured case study</span>
      <h3 class="mt-5 text-3xl font-extrabold text-[var(--color-text)] sm:text-4xl">{entry.data.title}</h3>
      <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">{entry.data.excerpt}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {
          entry.data.stack.map((item) => (
            <span class="chip text-sm">{item}</span>
          ))
        }
      </div>
      <a class="mt-8 inline-flex items-center gap-2 font-semibold text-[var(--color-brand)]" href={`/case-studies/${entry.id}`}>
        Read the case study
        <Icon icon={ArrowRight} class="size-4" />
      </a>
    </div>

    <div class="grid gap-4">
      {
        entry.data.metrics.slice(0, 4).map((metric) => (
          <div class="rounded-3xl border border-[rgba(255,255,255,0.08)] bg-[rgba(0,0,0,0.08)] px-5 py-4">
            <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">{metric.label}</p>
            <p class="mt-3 text-lg font-semibold text-[var(--color-text)]">{metric.value}</p>
          </div>
        ))
      }
    </div>
  </div>
</article>
