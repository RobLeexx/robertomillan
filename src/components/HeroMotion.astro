<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reducedMotion) {
    const heroRoot = document.querySelector('[data-hero-copy]')?.closest('section');

    if (heroRoot) {
      Promise.all([import('gsap')]).then(([gsapModule]) => {
        const gsap = gsapModule.gsap;

        const timeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

        timeline
          .from('[data-hero-copy] > *', { y: 28, autoAlpha: 0, duration: 0.8, stagger: 0.12 })
          .from('[data-hero-actions] > *', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.08 }, '-=0.35')
          .from('[data-hero-badges] > *', { y: 14, autoAlpha: 0, duration: 0.45, stagger: 0.05 }, '-=0.35')
          .from('[data-hero-stats] > *', { y: 18, autoAlpha: 0, duration: 0.5, stagger: 0.1 }, '-=0.28')
          .from('[data-hero-panel]', { x: 34, autoAlpha: 0, duration: 0.9 }, '-=0.7')
          .from('[data-hero-card]', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.12 }, '-=0.55');
      });
    }
  }
</script>
