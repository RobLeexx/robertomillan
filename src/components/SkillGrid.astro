---
import type { SkillGroup } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
  {
    groups.map((group) => (
      <article class="panel rounded-[1.75rem] p-6" data-reveal>
        <div class="flex items-center gap-4">
          <span class="inline-flex size-11 items-center justify-center rounded-2xl bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]">
            <Icon icon={group.icon} class="size-5" />
          </span>
          <h3 class="text-xl font-bold text-[var(--color-text)]">{group.title}</h3>
        </div>
        <ul class="mt-5 flex flex-wrap gap-2">
          {
            group.items.map((item) => (
              <li class="chip text-sm">{item}</li>
            ))
          }
        </ul>
      </article>
    ))
  }
</div>
