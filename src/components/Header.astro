---
import { Menu, MoveRight, X } from 'lucide-static';
import { navItems, siteMeta } from '../data/site';
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-[rgba(255,255,255,0.06)] bg-[var(--color-bg-soft)] backdrop-blur-xl">
  <div
    class="mx-auto flex w-full max-w-6xl items-center gap-4 px-6 py-4 lg:px-8"
    data-nav-root
    data-open="false"
  >
    <a class="group flex min-w-0 items-center gap-3" href="/">
      <span class="grid size-11 place-items-center rounded-2xl border border-[rgba(77,208,225,0.22)] bg-[rgba(77,208,225,0.12)] font-mono-display text-sm font-bold text-[var(--color-brand)]">
        RM
      </span>
      <span class="min-w-0">
        <span class="block truncate font-semibold text-[var(--color-text)]">{siteMeta.name}</span>
        <span class="block truncate text-sm text-[var(--color-muted)]">CRM, automation, fullstack delivery</span>
      </span>
    </a>

    <nav class="ml-auto hidden items-center gap-2 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-semibold',
              isActive(item.href)
                ? 'bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]'
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="ml-auto flex items-center gap-3 md:ml-0">
      <a class="button-secondary hidden md:inline-flex" href="/contact">
        Let&apos;s talk
        <Icon icon={MoveRight} class="size-4" />
      </a>
      <ThemeToggle />
      <button
        type="button"
        class="inline-flex size-11 items-center justify-center rounded-full border border-[var(--color-line)] bg-white/5 text-[var(--color-text)] md:hidden"
        data-nav-toggle
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span data-menu-open-icon>
          <Icon icon={Menu} class="size-5" />
        </span>
        <span class="hidden" data-menu-close-icon>
          <Icon icon={X} class="size-5" />
        </span>
        <span class="sr-only">Toggle navigation</span>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="panel absolute left-6 right-6 top-[calc(100%+0.75rem)] hidden rounded-3xl p-4 md:hidden"
      data-nav-drawer
    >
      <nav class="flex flex-col gap-2">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-2xl px-4 py-3 text-sm font-semibold',
                isActive(item.href)
                  ? 'bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]'
                  : 'text-[var(--color-text)] hover:bg-white/4'
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a class="button-primary mt-4 w-full" href="/contact">
        Start a project
        <Icon icon={MoveRight} class="size-4" />
      </a>
    </div>
  </div>
</header>
