---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import CTASection from '../../components/CTASection.astro';
import TimelineMotion from '../../components/TimelineMotion.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { callToAction } from '../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'case-studies'> };
const { Content } = await render(entry);
const readingTime = Math.max(3, Math.round((entry.body ?? '').split(/\s+/).filter(Boolean).length / 220));
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt}>
  <section class="mx-auto w-full max-w-6xl px-6 pb-18 pt-16 lg:px-8 lg:pb-24 lg:pt-22">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Case study</span>
        <h1 class="text-5xl font-extrabold tracking-tight text-[var(--color-text)] sm:text-6xl">
          {entry.data.title}
        </h1>
        <p class="max-w-3xl text-lg leading-9 text-[var(--color-muted)]">{entry.data.excerpt}</p>
        <div class="flex flex-wrap gap-3">
          <span class="chip text-sm">{entry.data.client}</span>
          <span class="chip text-sm">{entry.data.sector}</span>
          <span class="chip text-sm">{entry.data.duration}</span>
          <span class="chip text-sm">{readingTime} min read</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            entry.data.stack.map((item) => (
              <span class="chip text-sm">{item}</span>
            ))
          }
        </div>
      </div>

      <div class="panel-strong rounded-[2rem] p-8">
        <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">Project summary</p>
        <dl class="mt-6 grid gap-5">
          <div>
            <dt class="text-sm font-semibold text-[var(--color-text)]">Role</dt>
            <dd class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{entry.data.role}</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold text-[var(--color-text)]">Services</dt>
            <dd class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{entry.data.services.join(' / ')}</dd>
          </div>
          <div>
            <dt class="text-sm font-semibold text-[var(--color-text)]">Key outcomes</dt>
            <dd class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{entry.data.outcomes.join(' ')}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-4 lg:px-8 lg:py-8">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        entry.data.metrics.map((metric) => (
          <article class="panel rounded-[1.75rem] p-6" data-reveal>
            <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">{metric.label}</p>
            <p class="mt-4 text-xl font-bold text-[var(--color-text)]">{metric.value}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="space-y-5">
        <span class="eyebrow">Timeline</span>
        <h2 class="text-3xl font-extrabold text-[var(--color-text)] sm:text-4xl">
          A timeline shaped around business process needs
        </h2>
        <p class="text-base leading-8 text-[var(--color-muted)]">
          The implementation focused on reducing manual coordination and making the system reflect how the team actually sells and delivers work.
        </p>
      </div>
      <div class="space-y-5">
        {
          entry.data.timeline.map((item) => (
            <article class="panel rounded-[1.75rem] p-6" data-timeline-item>
              <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">{item.phase}</p>
              <p class="mt-4 text-base leading-8 text-[var(--color-muted)]">{item.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-4xl px-6 py-4 lg:px-8 lg:py-8">
    <article class="prose-shell panel rounded-[2rem] px-6 py-8 sm:px-10 sm:py-10" data-reveal>
      <Content />
    </article>
  </section>

  <CTASection {...callToAction} />
  <TimelineMotion />
</BaseLayout>
