---
import { ArrowUpRight } from 'lucide-static';
import CTASection from '../../components/CTASection.astro';
import Icon from '../../components/Icon.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { callToAction, contactChannels, siteMeta } from '../../data/site';
---

<BaseLayout
  title="Contact"
  description="Contact Roberto Millan for freelance, part-time, remote, or full-time opportunities in CRM development, fullstack delivery, and automation."
>
  <section class="mx-auto w-full max-w-6xl px-6 pb-18 pt-16 lg:px-8 lg:pb-24 lg:pt-22">
    <div class="grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">Contact</span>
        <h1 class="text-5xl font-extrabold tracking-tight text-[var(--color-text)] sm:text-6xl">
          Let&apos;s talk about your CRM, automation, or fullstack project
        </h1>
        <p class="max-w-3xl text-lg leading-9 text-[var(--color-muted)]">
          If you need an Odoo developer, a Django + React fullstack developer, a frontend specialist with product sense, or someone to untangle business workflows, I&apos;d be glad to hear about it.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a class="button-primary" href={`mailto:${siteMeta.email}?subject=Project%20Inquiry`}>
            Send an email
            <Icon icon={ArrowUpRight} class="size-4" />
          </a>
          <a class="button-secondary" href="/services">
            Review services
            <Icon icon={ArrowUpRight} class="size-4" />
          </a>
        </div>
      </div>

      <div class="panel-strong rounded-[2rem] p-8">
        <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">Availability</p>
        <p class="mt-4 text-2xl font-bold text-[var(--color-text)]">
          Open to part-time, freelance, and selected full-time remote roles
        </p>
        <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">
          Best fit for work involving custom CRM logic, operations software, workflow automation, or product delivery that spans design and implementation.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-4 lg:px-8 lg:py-8">
    <SectionIntro
      eyebrow="Contact channels"
      title="Ways to start the conversation"
      description="Keep it simple. A short summary of the project, current stack, and timeline is enough to start."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        contactChannels.map((channel) => (
          <a class="panel rounded-[1.75rem] p-6" data-reveal href={channel.href}>
            <span class="inline-flex size-11 items-center justify-center rounded-2xl bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]">
              <Icon icon={channel.icon} class="size-5" />
            </span>
            <h3 class="mt-5 text-xl font-bold text-[var(--color-text)]">{channel.title}</h3>
            <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{channel.value}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Good project inquiries"
      title="What to include in your message"
      description="This helps me respond with something useful instead of a generic reply."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      <article class="panel rounded-[1.75rem] p-6" data-reveal>
        <h3 class="text-xl font-bold text-[var(--color-text)]">The business problem</h3>
        <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">
          What is taking too much time, breaking too often, or creating friction for your team or customers?
        </p>
      </article>
      <article class="panel rounded-[1.75rem] p-6" data-reveal>
        <h3 class="text-xl font-bold text-[var(--color-text)]">The current stack</h3>
        <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">
          Whether you are using Odoo, Django, React, spreadsheets, or a mix of tools, the current setup shapes the best approach.
        </p>
      </article>
      <article class="panel rounded-[1.75rem] p-6" data-reveal>
        <h3 class="text-xl font-bold text-[var(--color-text)]">The timeline</h3>
        <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">
          Share whether this is an urgent improvement, an ongoing collaboration, or a project to scope carefully before building.
        </p>
      </article>
    </div>
  </section>

  <CTASection {...callToAction} />
</BaseLayout>
