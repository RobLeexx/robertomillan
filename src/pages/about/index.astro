---
import CTASection from '../../components/CTASection.astro';
import Icon from '../../components/Icon.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import SkillGrid from '../../components/SkillGrid.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { aboutPillars, callToAction, processSteps, siteMeta, skillGroups } from '../../data/site';
---

<BaseLayout
  title="About"
  description="About Roberto Millan, a Fullstack Developer specializing in CRM systems, custom business software, automation, and production deployments."
>
  <section class="mx-auto w-full max-w-6xl px-6 pb-18 pt-16 lg:px-8 lg:pb-24 lg:pt-22">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="space-y-6">
        <span class="eyebrow">About</span>
        <h1 class="max-w-3xl text-5xl font-extrabold tracking-tight text-[var(--color-text)] sm:text-6xl">
          Product-minded engineering for teams that need working systems, not just code.
        </h1>
        <p class="max-w-2xl text-lg leading-9 text-[var(--color-muted)]">
          I&apos;m a Fullstack Developer based in Spain, focused on building software that supports real operational workflows. My work sits at the intersection of product thinking, custom development, and process automation.
        </p>
        <p class="max-w-2xl text-base leading-8 text-[var(--color-muted)]">
          The projects I enjoy most involve CRM systems, internal tools, automation-heavy workflows, or platform work where frontend quality matters as much as backend reliability.
        </p>
      </div>
      <div class="panel-strong rounded-[2rem] p-8">
        <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-brand)]">Current focus</p>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-[var(--color-muted)]">
          <li>React and TypeScript interfaces that stay clean under real product complexity.</li>
          <li>Django and Python systems that hold up as business logic grows.</li>
          <li>Odoo customizations that match how teams actually sell, coordinate, and deliver.</li>
          <li>Deployment setups that reduce friction between development and production.</li>
        </ul>
        <div class="mt-8 rounded-3xl border border-[rgba(255,255,255,0.08)] bg-[rgba(0,0,0,0.08)] p-5">
          <p class="text-sm font-semibold text-[var(--color-text)]">{siteMeta.location}</p>
          <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
            Open to remote freelance, part-time, and selected full-time roles where product ownership and execution both matter.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="How I work"
      title="A delivery style that stays close to operations"
      description="The strongest projects usually come from understanding where people lose time, where data breaks, and where process friction becomes expensive."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        aboutPillars.map((pillar) => (
          <article class="panel rounded-[1.75rem] p-6" data-reveal>
            <span class="inline-flex size-11 items-center justify-center rounded-2xl bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]">
              <Icon icon={pillar.icon} class="size-5" />
            </span>
            <h3 class="mt-5 text-2xl font-bold text-[var(--color-text)]">{pillar.title}</h3>
            <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{pillar.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Stack"
      title="Tools that support fast, maintainable delivery"
      description="A mix of frontend, backend, CRM, and infrastructure capabilities that work especially well for custom business products."
    />
    <div class="mt-10">
      <SkillGrid groups={skillGroups} />
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-18 lg:px-8 lg:py-24">
    <SectionIntro
      eyebrow="Process"
      title="From workflow mapping to production launch"
      description="A simple collaboration model designed to reduce ambiguity and move quickly without losing technical clarity."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-4">
      {
        processSteps.map((step, index) => (
          <article class="panel rounded-[1.75rem] p-6" data-reveal>
            <p class="font-mono-display text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Step {index + 1}</p>
            <span class="mt-4 inline-flex size-11 items-center justify-center rounded-2xl bg-[rgba(77,208,225,0.12)] text-[var(--color-brand)]">
              <Icon icon={step.icon} class="size-5" />
            </span>
            <h3 class="mt-5 text-xl font-bold text-[var(--color-text)]">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{step.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <CTASection {...callToAction} />
</BaseLayout>
